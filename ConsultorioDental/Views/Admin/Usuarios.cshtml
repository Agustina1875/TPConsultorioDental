@model IEnumerable<ConsultorioDental.Controllers.UserRoleViewModel>
@{
    ViewData["Title"] = "Usuarios y roles";
    var rolesValidos = new List<string> { "Administrador", "Odontologo", "Paciente" };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold mb-1" style="color:#44B4C4;">Usuarios y roles</h1>
        <p class="text-muted mb-0">Asigná el rol de cada usuario registrado en el sistema.</p>
    </div>
    <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        ← Volver al panel
    </a>
</div>

@*//descripcion de lo que puede hacer cada rol dentro del sistema*@
<div class="row g-3 mb-4">
    <div class="col-md-4">
        @*//administrador tiene el rol de maximo acceso: gestiona todo el consultorio*@
        <div class="card border-0 shadow-sm p-3 h-100" style="border-left:4px solid #44B4C4 !important;">
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="bi bi-shield-fill-check" style="color:#44B4C4; font-size:1.1rem;"></i>
                <p class="fw-bold mb-0" style="color:#44B4C4;">Administrador</p>
            </div>
            <p class="text-muted small mb-0">Control total del sistema. Registra y edita pacientes, gestiona el equipo odontologico, administra turnos y asigna roles a los usuarios.</p>
        </div>
    </div>
    <div class="col-md-4">
        @*//odontologo tiene el rol de ver su propia agenda y registrar asistencia*@
        <div class="card border-0 shadow-sm p-3 h-100" style="border-left:4px solid #20c997 !important;">
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="bi bi-person-badge-fill" style="color:#20c997; font-size:1.1rem;"></i>
                <p class="fw-bold mb-0" style="color:#20c997;">Odontologo</p>
            </div>
            <p class="text-muted small mb-0">Acceso a su agenda personal de turnos. Visualiza los datos de sus pacientes y puede registrar asistencia o inasistencia en cada consulta.</p>
        </div>
    </div>
    <div class="col-md-4">
        @*//paciente tiene el rol de ver su panel personal y gestionar sus propios turnos*@
        <div class="card border-0 shadow-sm p-3 h-100" style="border-left:4px solid #6c757d !important;">
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="bi bi-person-circle" style="color:#6c757d; font-size:1.1rem;"></i>
                <p class="fw-bold mb-0" style="color:#6c757d;">Paciente</p>
            </div>
            <p class="text-muted small mb-0">Rol asignado por defecto al registrarse. Puede consultar su panel personal, ver sus datos y gestionar sus propios turnos (confirmar o cancelar).</p>
        </div>
    </div>
</div>

<!-- Tabla de usuarios -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="p-5 text-center text-muted">
                <div style="font-size:3rem;">👤</div>
                <p class="mt-3">No hay usuarios registrados aún.</p>
                <small>Los usuarios aparecen acá después de ingresar con Google por primera vez.</small>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background-color:#44B4C4; color:white;">
                        <tr>
                            <th class="ps-4 py-3">Nombre</th>
                            <th class="py-3">Email</th>
                            <th class="py-3 text-center">Rol actual</th>
                            <th class="py-3">Cambiar rol</th>
                            <th class="py-3 text-center">Guardar</th>
                            <th class="py-3 text-center">Eliminar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            var rolActual = u.Roles.FirstOrDefault() ?? "";
                            var badgeColor = rolActual switch
                            {
                                "Administrador" => "#44B4C4",
                                "Odontologo" => "#20c997",
                                "Paciente" => "#6c757d",
                                _ => "#dee2e6"
                            };

                            <tr>
                                <td class="ps-4 fw-semibold">@(u.NombreCompleto ?? "—")</td>
                                <td class="text-muted small">@u.Email</td>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(rolActual))
                                    {
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background-color:@badgeColor; font-size:.78rem;">
                                            @rolActual
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted border px-3 py-2"
                                              style="font-size:.78rem;">Sin rol</span>
                                    }
                                </td>
                                <td>
                                    <form asp-controller="Admin" asp-action="AsignarRol"
                                          method="post" id="form-@u.UserId">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@u.UserId" />

                                        <select name="role"
                                                class="form-select form-select-sm"
                                                style="width:160px; border-radius:8px;">
                                            @foreach (var r in rolesValidos)
                                            {
                                                <option value="@r" selected="@(rolActual == r ? "selected" : null)">
                                                    @r
                                                </option>
                                            }
                                        </select>
                                    </form>
                                </td>

                                <td class="text-center">
                                    <button type="submit"
                                            form="form-@u.UserId"
                                            class="btn btn-sm btn-dental"
                                            title="Guardar">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                </td>
                                <td class="text-center pe-3">
                                    <form asp-controller="Admin" asp-action="EliminarUsuario"
                                          method="post"
                                          onsubmit="return confirm('¿Seguro que querés eliminar este usuario?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@u.UserId" />

                                        <button type="submit" class="btn btn-sm btn-outline-delete px-2" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="alert border-0 mt-4 small"
     style="background-color:#f0fbfc; border-left:4px solid #44B4C4 !important; border-radius:10px;">
    <strong>¿No aparece un usuario?</strong> El usuario debe haber ingresado al sistema al menos
    una vez con Google para registrarse. Los nuevos usuarios reciben automáticamente el rol
    <strong>Paciente</strong>.
</div>

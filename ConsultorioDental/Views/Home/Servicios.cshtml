@{
    ViewData["Title"] = "Servicios";
}

<div class="page-header">
    <h1>Nuestros servicios</h1>
    <p>Conocé los tratamientos que ofrecemos en el consultorio.</p>
</div>

<div class="row g-4">

    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius:16px; transition: transform .2s;">
            <div class="card-body p-4 text-center">
                <div class="mb-3" style="font-size:2.8rem;">🦷</div>
                <h5 class="fw-bold">Odontología general</h5>
                <p class="text-muted small mb-0">
                    Controles periódicos, diagnóstico precoz y tratamiento de caries.
                    Cuidamos la salud bucal con seguimiento continuo y atención preventiva.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius:16px;">
            <div class="card-body p-4 text-center">
                <div class="mb-3" style="font-size:2.8rem;">✨</div>
                <h5 class="fw-bold">Implantes dentales</h5>
                <p class="text-muted small mb-0">
                    Reemplazo de piezas perdidas con implantes de titanio de alta durabilidad.
                    Resultado natural, funcional y estético para toda la vida.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius:16px;">
            <div class="card-body p-4 text-center">
                <div class="mb-3" style="font-size:2.8rem;">😬</div>
                <h5 class="fw-bold">Ortodoncia y brackets</h5>
                <p class="text-muted small mb-0">
                    Corrección de la alineación dental con brackets metálicos, cerámicos
                    o alineadores transparentes. Tratamos niños, adolescentes y adultos.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius:16px;">
            <div class="card-body p-4 text-center">
                <div class="mb-3" style="font-size:2.8rem;">💎</div>
                <h5 class="fw-bold">Estética dental</h5>
                <p class="text-muted small mb-0">
                    Blanqueamiento, carillas de porcelana y resina para transformar tu sonrisa.
                    Resultados visibles desde la primera sesión.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius:16px;">
            <div class="card-body p-4 text-center">
                <div class="mb-3" style="font-size:2.8rem;">🔬</div>
                <h5 class="fw-bold">Endodoncia</h5>
                <p class="text-muted small mb-0">
                    Tratamiento de conductos para salvar dientes con infección profunda,
                    sin dolor gracias a técnicas modernas y anestesia local eficaz.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius:16px;">
            <div class="card-body p-4 text-center">
                <div class="mb-3" style="font-size:2.8rem;">🧒</div>
                <h5 class="fw-bold">Odontopediatría</h5>
                <p class="text-muted small mb-0">
                    Atención especializada para los más chicos en un ambiente amigable.
                    Controles, selladores y tratamientos adaptados a la dentición primaria.
                </p>
            </div>
        </div>
    </div>

</div>

<div class="text-center mt-5">
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dental">
        <i class="bi bi-arrow-left me-1"></i> Volver al inicio
    </a>
</div>

@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center mt-5">
    <h1><i class="bi bi-tooth"></i> Bienvenido al consultorio dental</h1>
    <p class="text-muted mt-2">Sistema de gestión de pacientes y turnos</p>

    @if (User.Identity.IsAuthenticated)
    {
        <a asp-controller="Pacientes" asp-action="Index" class="btn btn-primary mt-3">
            <i class="bi bi-people"></i> Ver Pacientes
        </a>
    }
    else
    {
        <a asp-controller="Cuenta" asp-action="Login" class="btn btn-primary mt-3">
            <i class="bi bi-box-arrow-in-right"></i> Iniciar Sesión
        </a>
    }
</div>
@model IEnumerable<ConsultorioDental.Models.Paciente>
@{
    ViewData["Title"] = "Pacientes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold mb-1" style="color:#44B4C4;">Pacientes</h1>
        <p class="text-muted mb-0">Listado de pacientes registrados. Desde acá podés ver sus datos y eliminarlos si hace falta.</p>
    </div>
    <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary btn-sm">← Volver al panel</a>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success border-0 rounded-3 mb-3">@TempData["Mensaje"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger border-0 rounded-3 mb-3">@TempData["Error"]</div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background-color:#44B4C4; color:white;">
                        <tr>
                            <th class="py-3">Nombre</th>
                            <th class="py-3">DNI</th>
                            <th class="py-3">Teléfono</th>
                            <th class="py-3">Email</th>
                            <th class="py-3 text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@p.NombreCompleto</td>
                                <td class="text-muted">@p.DNI</td>
                                <td class="text-muted">@p.Telefono</td>
                                <td class="text-muted">@p.Email</td>
                                <td class="text-center pe-3">
                                    <a asp-action="Eliminar" asp-route-id="@p.Id" class="btn btn-sm btn-outline-delete">Eliminar</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-5 text-center text-muted">
                <div style="font-size:3rem;">👤</div>
                <p class="mt-3 mb-0">Todavía no hay pacientes registrados.</p>
            </div>
        }
    </div>
</div>

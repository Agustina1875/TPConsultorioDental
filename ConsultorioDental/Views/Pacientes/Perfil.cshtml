@model ConsultorioDental.Models.Paciente
@{
    ViewData["Title"] = "Perfil de " + Model.NombreCompleto;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold mb-1" style="color:#44B4C4;">Perfil del paciente</h1>
        <p class="text-muted mb-0">Vista completa con datos personales e historial de turnos.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-dental">Editar</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4 overflow-hidden">
    <div class="p-4 p-md-5" style="background: linear-gradient(135deg, #44B4C4 0%, #74d4df 100%); color: white;">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h2 class="fw-bold mb-1">@Model.NombreCompleto</h2>
                <p class="mb-0 opacity-75">Paciente registrado en el consultorio</p>
            </div>
            <span class="badge rounded-pill px-3 py-2" style="background: rgba(255,255,255,.18); border: 1px solid rgba(255,255,255,.35);">
                DNI @Model.DNI
            </span>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm p-4 mb-3">
            <h5 class="fw-bold mb-3" style="color:#44B4C4;">Datos personales</h5>
            <div class="row g-3">
                <div class="col-sm-6 col-lg-3">
                    <p class="text-muted small mb-1">DNI</p>
                    <p class="fw-semibold mb-0">@Model.DNI</p>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <p class="text-muted small mb-1">Fecha de nacimiento</p>
                    <p class="fw-semibold mb-0">@Model.FechaNacimiento.ToString("dd/MM/yyyy")</p>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <p class="text-muted small mb-1">Teléfono</p>
                    <p class="fw-semibold mb-0">@Model.Telefono</p>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <p class="text-muted small mb-1">Email</p>
                    <p class="fw-semibold mb-0">@Model.Email</p>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card border-0 shadow-sm p-4">
            <h5 class="fw-bold mb-3" style="color:#44B4C4;">Historial de turnos</h5>
            @if (Model.Turnos != null && Model.Turnos.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead style="background-color:#44B4C4; color:white;">
                            <tr>
                                <th class="px-3">Fecha</th>
                                <th>Odontólogo</th>
                                <th>Motivo</th>
                                <th class="text-center">Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.Turnos.OrderByDescending(t => t.FechaHora))
                            {
                                var badge = t.Estado switch
                                {
                                    "Confirmado" => "bg-success",
                                    "Cancelado" => "bg-danger",
                                    "Completado" => "bg-primary",
                                    "Inasistencia" => "bg-danger",
                                    _ => "bg-warning text-dark"
                                };
                                <tr>
                                    <td class="px-3">@t.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@(t.Odontologo?.NombreCompleto ?? "—")</td>
                                    <td>@(t.Motivo ?? "—")</td>
                                    <td class="text-center">
                                        <span class="badge @badge">@t.Estado</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted small mb-0">Este paciente no tiene turnos registrados.</p>
            }
        </div>
    </div>
</div>

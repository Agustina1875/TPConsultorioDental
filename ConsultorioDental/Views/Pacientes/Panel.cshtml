@model ConsultorioDental.Models.Paciente?
@{
    ViewData["Title"] = "Mi Panel";
}

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success border-0 rounded-3 mb-3">@TempData["Mensaje"]</div>
}

@if (Model == null)
{
    <div class="mb-4">
        <h1 class="fw-bold mb-1" style="color:#44B4C4;">Mi panel</h1>
        <p class="text-muted">Bienvenido/a al sistema Dental System.</p>
    </div>
    <div class="alert alert-warning border-0 rounded-3">
        <strong>Tu cuenta aún no está vinculada a un paciente.</strong>
        Contactá al administrador del consultorio para que registre tus datos.
    </div>
}
else
{
    <div class="mb-4">
        <h1 class="fw-bold mb-1" style="color:#44B4C4;">Bienvenido/a, @Model.NombreCompleto</h1>
        <p class="text-muted">Este es tu espacio personal en Dental System.</p>
    </div>

    @*//seccion compacta con los datos personales del paciente*@
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body px-4 py-3">
            <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">
                <div class="d-flex gap-4 flex-wrap">
                    <div>
                        <p class="text-muted mb-0" style="font-size:.7rem;text-transform:uppercase;letter-spacing:.05em;">Nombre</p>
                        <p class="fw-semibold mb-0 small">@Model.NombreCompleto</p>
                    </div>
                    <div>
                        <p class="text-muted mb-0" style="font-size:.7rem;text-transform:uppercase;letter-spacing:.05em;">DNI</p>
                        <p class="fw-semibold mb-0 small">@Model.DNI</p>
                    </div>
                    <div>
                        <p class="text-muted mb-0" style="font-size:.7rem;text-transform:uppercase;letter-spacing:.05em;">Nacimiento</p>
                        <p class="fw-semibold mb-0 small">@Model.FechaNacimiento.ToString("dd/MM/yyyy")</p>
                    </div>
                    <div>
                        <p class="text-muted mb-0" style="font-size:.7rem;text-transform:uppercase;letter-spacing:.05em;">Teléfono</p>
                        <p class="fw-semibold mb-0 small">@Model.Telefono</p>
                    </div>
                    <div>
                        <p class="text-muted mb-0" style="font-size:.7rem;text-transform:uppercase;letter-spacing:.05em;">Email</p>
                        <p class="fw-semibold mb-0 small">@Model.Email</p>
                    </div>
                </div>
                <a asp-action="EditarPerfil" class="btn btn-sm btn-outline-secondary flex-shrink-0">
                    <i class="bi bi-pencil me-1"></i>Editar perfil
                </a>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0" style="color:#44B4C4;">Mis turnos</h5>
                <a asp-controller="Turnos" asp-action="MisTurnosPaciente" class="btn btn-sm btn-outline-secondary">
                    Ver todos
                </a>
            </div>

            @if (Model.Turnos.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead style="background-color:#44B4C4; color:white;">
                            <tr>
                                <th class="px-3 py-2">Fecha y hora</th>
                                <th class="py-2">Odontólogo</th>
                                <th class="py-2">Motivo</th>
                                <th class="py-2 text-center">Estado</th>
                                <th class="py-2 text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.Turnos.OrderBy(t => t.FechaHora))
                            {
                                var badge = t.Estado switch
                                {
                                    "Confirmado" => "bg-success",
                                    "Cancelado" => "bg-danger",
                                    "Completado" => "bg-primary",
                                    "Inasistencia" => "bg-danger",
                                    _ => "bg-warning text-dark"
                                };
                                <tr>
                                    <td class="px-3">@t.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@(t.Odontologo?.NombreCompleto ?? "—")</td>
                                    <td class="text-muted small">@(t.Motivo ?? "—")</td>
                                    <td class="text-center">
                                        <span class="badge @badge">@t.Estado</span>
                                    </td>
                                    <td class="text-center">
                                        @if (t.Estado == "Pendiente")
                                        {
                                            <div class="d-flex gap-1 justify-content-center">
                                                <form asp-controller="Turnos" asp-action="Confirmar"
                                                      asp-route-id="@t.Id" method="post"
                                                      onsubmit="return confirm('¿Confirmás tu asistencia a este turno?')">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-confirmar">Confirmar</button>
                                                </form>
                                                <form asp-controller="Turnos" asp-action="Cancelar"
                                                      asp-route-id="@t.Id" method="post"
                                                      onsubmit="return confirm('¿Seguro que querés cancelar este turno?')">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-delete">Cancelar</button>
                                                </form>
                                            </div>
                                        }
                                        else if (t.Estado == "Confirmado")
                                        {
                                            <form asp-controller="Turnos" asp-action="Cancelar"
                                                  asp-route-id="@t.Id" method="post"
                                                  onsubmit="return confirm('¿Seguro que querés cancelar este turno ya confirmado?')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-delete">Cancelar</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No tenés turnos registrados aún.</p>
            }
        </div>
    </div>
}

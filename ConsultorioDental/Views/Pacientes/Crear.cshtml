@model ConsultorioDental.Models.Paciente
@{
    ViewData["Title"] = "Nuevo paciente";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Nuevo paciente</h2>
        <p class="text-muted mb-0">Completá los datos para registrar un nuevo paciente.</p>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-4">
        <form asp-action="Crear" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Nombre" class="form-label fw-semibold"></label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej: Juan" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Apellido" class="form-label fw-semibold"></label>
                    <input asp-for="Apellido" class="form-control" placeholder="Ej: García" />
                    <span asp-validation-for="Apellido" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="DNI" class="form-label fw-semibold"></label>
                    <input asp-for="DNI" class="form-control" placeholder="Ej: 35123456" />
                    <span asp-validation-for="DNI" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="FechaNacimiento" class="form-label fw-semibold"></label>
                    <input asp-for="FechaNacimiento" type="date" class="form-control" />
                    <span asp-validation-for="FechaNacimiento" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Telefono" class="form-label fw-semibold"></label>
                    <input asp-for="Telefono" class="form-control" placeholder="Ej: 11-4567-8900" />
                    <span asp-validation-for="Telefono" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="correo@ejemplo.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-dental px-4 fw-semibold">Guardar</button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

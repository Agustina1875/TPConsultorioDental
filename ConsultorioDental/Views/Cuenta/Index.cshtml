@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center">
                <h3 class="card-title mb-4">Consultorio Dental</h3>
                <p class="text-muted">Inicia sesión con tu cuenta de Google</p>
                <a asp-controller="Cuenta" asp-action="LoginGoogle" class="btn btn-danger btn-lg w-100">
                    <i class="bi bi-google"></i> Ingresar con Google
                </a>
            </div>
        </div>
    </div>
</div>
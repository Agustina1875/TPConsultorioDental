@model ConsultorioDental.Models.Odontologo
@{
    ViewData["Title"] = "Eliminar odontólogo";
}

<div class="row justify-content-center mt-3">
    <div class="col-md-6 col-lg-5">
        <div class="card card-form" style="border-radius:16px;">
            <div class="card-body p-4 p-md-5 text-center">

                <div class="mb-3">
                    <i class="bi bi-exclamation-triangle-fill" style="color:#1d7f8f;" style="font-size:3rem;"></i>
                </div>

                <h4 class="fw-bold mb-1">¿Eliminar odontólogo?</h4>
                <p class="text-muted mb-4">
                    Esta acción no se puede deshacer. Vas a eliminar a
                    <strong>@Model.NombreCompleto</strong> del sistema.
                </p>

                <div class="bg-light rounded-3 p-3 text-start mb-4 small">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Especialidad</span>
                        <span class="fw-semibold">@Model.Especialidad</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Teléfono</span>
                        <span>@Model.Telefono</span>
                    </div>
                </div>

                <form asp-action="Eliminar">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="submit" class="btn btn-delete px-4 fw-semibold">
                            <i class="bi bi-trash me-1"></i>Sí, eliminar
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

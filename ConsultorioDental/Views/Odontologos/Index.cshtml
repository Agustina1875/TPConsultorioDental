@model IEnumerable<ConsultorioDental.Models.Odontologo>
@{
    ViewData["Title"] = "Odontólogos";
}

<div class="page-header d-flex justify-content-between align-items-start flex-wrap gap-2">
    <div>
        <h1><i class="bi bi-person-badge me-2"></i>Odontólogos</h1>
        <p>Listado del equipo profesional. Desde administración solo se visualizan y se eliminan si hace falta.</p>
    </div>
    <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary btn-sm">← Volver al panel</a>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success border-0 rounded-3 mb-3">@TempData["Mensaje"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger border-0 rounded-3 mb-3">@TempData["Error"]</div>
}

<div class="card card-form">
    <div class="card-body p-0">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-dental table-hover mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Nombre</th>
                            <th>Especialidad</th>
                            <th>Teléfono</th>
                            <th>Email</th>
                            <th class="text-center">Turnos</th>
                            <th class="text-center pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold">@o.NombreCompleto</td>
                                <td class="text-muted">@o.Especialidad</td>
                                <td class="text-muted">@o.Telefono</td>
                                <td class="text-muted">@o.Email</td>
                                <td class="text-center">
                                    <a asp-controller="Turnos" asp-action="Index" asp-route-odontologoId="@o.Id"
                                       class="badge bg-primary text-decoration-none fs-6 px-3 py-2"
                                       title="Ver turnos de @o.NombreCompleto">
                                        @o.Turnos.Count
                                    </a>
                                </td>
                                <td class="text-center pe-4">
                                    <a asp-action="Eliminar" asp-route-id="@o.Id" class="btn btn-sm btn-outline-delete">
                                        <i class="bi bi-trash me-1"></i>Eliminar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <span class="empty-icon">🩺</span>
                <p class="fw-semibold mb-1">No hay odontólogos registrados</p>
                <p class="small mb-0">Van a aparecer cuando un usuario tenga rol de odontólogo y complete su perfil.</p>
            </div>
        }
    </div>
</div>

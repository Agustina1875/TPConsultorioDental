@model ConsultorioDental.Models.Odontologo
@{
    ViewData["Title"] = "Nuevo odontólogo";
}

<div class="page-header">
    <h1><i class="bi bi-person-badge me-2"></i>Nuevo odontólogo</h1>
    <p>Completá los datos para registrar un profesional.</p>
</div>

<div class="alert alert-light border mb-4">
    Al guardar, también se crea la cuenta del odontólogo con una contraseña provisoria. Después la puede cambiar desde <strong>Editar perfil</strong>.
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card card-form">
            <div class="card-body p-4 p-md-5">
                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <p class="form-section-title">Datos del profesional</p>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Nombre" class="form-label fw-semibold"></label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ej: María" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Apellido" class="form-label fw-semibold"></label>
                            <input asp-for="Apellido" class="form-control" placeholder="Ej: López" />
                            <span asp-validation-for="Apellido" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Especialidad" class="form-label fw-semibold"></label>
                            <input asp-for="Especialidad" class="form-control" placeholder="Ej: Ortodoncia" />
                            <span asp-validation-for="Especialidad" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label fw-semibold"></label>
                            <input asp-for="Telefono" class="form-control" placeholder="Ej: 11-5678-9000" />
                            <span asp-validation-for="Telefono" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" type="email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-dental px-4">
                            <i class="bi bi-check-lg me-1"></i>Guardar
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

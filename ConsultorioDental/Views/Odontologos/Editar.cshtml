@model ConsultorioDental.Models.Odontologo
@{
    ViewData["Title"] = "Editar odontólogo";
}

<div class="page-header">
    <h1><i class="bi bi-pencil me-2"></i>Editar odontólogo</h1>
    <p>Modificá los datos del profesional seleccionado.</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card card-form">
            <div class="card-body p-4 p-md-5">

                <form asp-action="Editar" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <p class="form-section-title">Datos del profesional</p>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Nombre" class="form-label fw-semibold"></label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Apellido" class="form-label fw-semibold"></label>
                            <input asp-for="Apellido" class="form-control" />
                            <span asp-validation-for="Apellido" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Especialidad" class="form-label fw-semibold"></label>
                            <input asp-for="Especialidad" class="form-control" />
                            <span asp-validation-for="Especialidad" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label fw-semibold"></label>
                            <input asp-for="Telefono" class="form-control" />
                            <span asp-validation-for="Telefono" class="text-danger small"></span>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" type="email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-dental px-4">
                            <i class="bi bi-check-lg me-1"></i>Guardar cambios
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Dental System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg navbar-dental">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <i class="bi bi-tooth-fill fs-4"></i>
                <span>Dental System</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav me-auto">

                    @if (User.Identity?.IsAuthenticated != true)
                    {
                        <li class="nav-item"><a class="nav-link" href="/#inicio">Inicio</a></li>
                        <li class="nav-item"><a class="nav-link" href="/#quienes-somos">Quiénes somos</a></li>
                        <li class="nav-item"><a class="nav-link" href="/#servicios">Servicios</a></li>
                        <li class="nav-item"><a class="nav-link" href="/#contacto">Contacto</a></li>
                    }
                    @*//administrador: acceso a panel de gestion, pacientes, odontologos, turnos y usuarios*@
                    else if (User.IsInRole("Administrador"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i>Panel
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-grid me-1"></i>Gestión
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-controller="Paciente" asp-action="Index">
                                        <i class="bi bi-people me-2 text-muted"></i>Pacientes
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Odontologos" asp-action="Index">
                                        <i class="bi bi-person-badge me-2 text-muted"></i>Odontólogos
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Turnos" asp-action="Index">
                                        <i class="bi bi-calendar3 me-2 text-muted"></i>Turnos
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Admin" asp-action="Usuarios">
                                        <i class="bi bi-shield-lock me-2 text-muted"></i>Usuarios y roles
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    @*//odontologo: solo ve su agenda personal de turnos asignados*@
                    else if (User.IsInRole("Odontologo"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Turnos" asp-action="MisTurnos">
                                <i class="bi bi-calendar-check me-1"></i>Mis turnos
                            </a>
                        </li>
                    }
                    @*//paciente: accede a su panel personal con sus datos y sus turnos*@
                    else if (User.IsInRole("Paciente"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Paciente" asp-action="Panel">
                                <i class="bi bi-person-circle me-1"></i>Mi panel
                            </a>
                        </li>
                    }

                </ul>

                <ul class="navbar-nav">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-1"
                               href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle fs-5"></i>
                                <span class="d-none d-lg-inline">@User.Identity.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" asp-controller="Home" asp-action="Dashboard">
                                        <i class="bi bi-house me-2 text-muted"></i>Mi panel
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Cuenta" asp-action="Logout" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Cerrar sesión
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-light fw-semibold ms-lg-2 px-3" style="color: var(--dental-dark);"
                               asp-controller="Cuenta" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Iniciar sesión
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-light fw-semibold ms-lg-2 px-3"
                               asp-controller="Cuenta" asp-action="Registro">
                                <i class="bi bi-person-plus me-1"></i>Registrarse
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="container my-3 flex-fill">
        @RenderBody()
    </main>

    <footer class="footer-dental text-center py-4 mt-auto">
        <div class="container">
            <small>
                <i class="bi bi-tooth-fill me-1"></i>
                <strong>Dental System</strong> &mdash; Consultorio Odontológico &bull; CABA &bull;
                &copy; @DateTime.Now.Year
            </small>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
